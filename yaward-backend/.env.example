# Environment Configuration
# Copy this file to .env and fill in the values

# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=yaward-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://yaward:yaward123@localhost:5432/yaward_db

# YOLOv8 Model
MODEL_PATH=yolov8_ppe.pt
CONFIDENCE_THRESHOLD=0.7
IOU_THRESHOLD=0.45

# Alert Email Settings (optional for MVP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_RECIPIENTS=supervisor@company.com

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server
HOST=0.0.0.0
PORT=5000
